---
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage
  frontmatter={{
    title: 'moon-wave',
    template: 'splash',
    hero: {
      title: 'Build AI agents on Cloudflare',
      tagline: 'TypeScript framework for Cloudflare Workers — tools, memory, multi-agent, channels out of the box.',
      actions: [
        { text: 'Get Started', link: '/getting-started/quick-start', icon: 'right-arrow', variant: 'primary' },
        { text: 'GitHub', link: 'https://github.com/linhhang1412/moon-wave', icon: 'github', variant: 'minimal' },
      ],
    },
  }}
>
  <div class="features">
    <div class="feature">
      <h3>⚡ Zero cold starts</h3>
      <p>Runs natively on Cloudflare's edge network — no servers to manage.</p>
    </div>
    <div class="feature">
      <h3>🧠 Built-in memory</h3>
      <p>KV for sessions, D1 for persistence, Vectorize for semantic search.</p>
    </div>
    <div class="feature">
      <h3>🤖 Multi-provider</h3>
      <p>Groq, Google Gemini, Cerebras, Workers AI — one unified interface.</p>
    </div>
    <div class="feature">
      <h3>🔧 Composable</h3>
      <p>Tools, multi-agent networks, graph-based workflows — mix and match.</p>
    </div>
    <div class="feature">
      <h3>📡 Channels</h3>
      <p>Connect your agent to Telegram or Web Chat with a few lines of code.</p>
    </div>
    <div class="feature">
      <h3>🔍 Observable</h3>
      <p>OpenTelemetry-style distributed tracing built in from day one.</p>
    </div>
  </div>

  <div class="install">
    <code>npx create-moon-wave-app my-agent</code>
  </div>
</StarlightPage>

<style>
  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin: 3rem 0;
  }
  .feature {
    padding: 1.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
  }
  .feature h3 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
  }
  .feature p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
  }
  .install {
    text-align: center;
    margin: 2rem 0;
  }
  .install code {
    background: var(--sl-color-gray-6);
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 1rem;
  }
</style>
