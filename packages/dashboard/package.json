{
  "name": "@moon-wave/dashboard",
  "version": "0.1.0",
  "description": "Self-hosted dashboard for moon-wave agents — playground, traces, sessions",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "node build-client.mjs && tsup src/index.ts --format esm --dts --clean",
    "build:client": "node build-client.mjs",
    "typecheck": "tsc --noEmit && tsc --project src/client/tsconfig.json --noEmit",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@moon-wave/core": "workspace:*",
    "@moon-wave/memory": "workspace:*",
    "@moon-wave/types": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "author": "linhhang1412",
  "license": "MIT",
  "homepage": "https://github.com/linhhang1412/moon-wave#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linhhang1412/moon-wave.git"
  },
  "bugs": {
    "url": "https://github.com/linhhang1412/moon-wave/issues"
  }
}
